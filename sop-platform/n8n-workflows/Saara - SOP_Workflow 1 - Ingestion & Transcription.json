        "body": "={{ JSON.stringify({ contents: [{ parts: [{ file_data: { mime_type: 'video/mp4', file_uri: $json.uri } }, { text: 'You are a professional transcriptionist. Your task is to produce a VERBATIM, word-for-word transcript of this meeting recording. Capture every spoken word exactly as said — do NOT paraphrase, summarize, clean up, or improve the language. Include filler words (um, uh, like, you know), false starts, repetitions, and incomplete sentences exactly as they occur in the audio.\\n\\nFor each speaker turn provide: the speaker name, start time (MM:SS), end time (MM:SS), and the exact verbatim spoken text. Also identify every moment where the shared screen content changes visually.\\n\\nReturn ONLY valid JSON in this exact format:\\n{\\n  \"speakers\": [\"name1\", \"name2\"],\\n  \"transcript\": [\\n    {\"speaker\": \"name\", \"start\": \"MM:SS\", \"end\": \"MM:SS\", \"text\": \"exact verbatim spoken words\"}\\n  ],\\n  \"screen_changes\": [\\n    {\"timestamp\": \"MM:SS\", \"description\": \"what is now visible on screen\"}\\n  ],\\n  \"meeting_participants\": [\"full names mentioned\"]\\n}' }] }], generationConfig: { temperature: 0.1, responseMimeType: 'application/json', maxOutputTokens: 65536 } }) }}",
        "options": {
          "timeout": 900000
        }
      },
      "id": "732c7387-88c2-40e5-a69a-04891e47298a",
      "name": "Gemini Transcription",
      "type": "n8n-nodes-base.httpRequest",
