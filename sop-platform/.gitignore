# Environment — NEVER commit secrets
.env

# Node
node_modules/
.vite/
dist/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/

# Data directories — keep structure (.gitkeep), ignore content
data/uploads/*
data/frames/*
data/exports/*
data/templates/*.docx
!data/templates/sop_template.docx
!data/**/.gitkeep
# Extractor temp dirs (created in /data to avoid container /tmp size limit)
data/sop_*/
data/sop_clips_*/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# n8n workflows — local only, not tracked in repo
n8n-workflows/
