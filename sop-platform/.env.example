# ============================================================
# SOP Automation Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database (Supabase) ───────────────────────────────────
# Use the transaction pooling connection string from Supabase dashboard:
# Project → Settings → Database → Connection string → Transaction pooler
# IMPORTANT: Transaction pooler uses port 6543, not 5432
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Backend API ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","https://sop.yourdomain.com"]

# Azure Blob Storage (leave blank for local development)
AZURE_BLOB_BASE_URL=
AZURE_BLOB_SAS_TOKEN=

# ── Frame Extractor ───────────────────────────────────────
EXTRACTOR_URL=http://sop-extractor:8001

# ── n8n (self-hosted at azuren8n.cloudnavision.com) ───────
N8N_WEBHOOK_BASE_URL=https://azuren8n.cloudnavision.com/webhook

# ── Pipeline Security ──────────────────────────────────────
# Shared secret between n8n and sop-api
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# n8n HTTP node must send header: x-internal-key: <this value>
INTERNAL_API_KEY=

# ── AI APIs ───────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=

# ── Frontend ──────────────────────────────────────────────
# API URL the frontend uses to call the backend directly
# (No nginx proxy — frontend calls API directly)
# Local dev:  http://localhost:8000
# Production: https://api.sop.yourdomain.com (Cloudflare-exposed URL)
VITE_API_URL=http://localhost:8000

# ── Supabase Auth (Phase 1.5) ─────────────────────────────
# Supabase Dashboard → Settings → API
# Project URL (public)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Backend alias — must match VITE_SUPABASE_URL value
SUPABASE_URL=https://your-project-ref.supabase.co
# Anon public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# JWT Secret (backend only — used to validate auth tokens)
# Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Cloudflare Tunnel ─────────────────────────────────────
# cloudflared runs as a HOST DAEMON (not a Docker container).
# TL sets this up once on the host machine:
#   cloudflared tunnel run --token <TOKEN>
#   Or install as Windows service: cloudflared service install --token <TOKEN>
#
# Tunnel route (configured in Cloudflare Zero Trust dashboard):
#   soptest.cloudnavision.com → http://localhost:8000  (sop-api — the ONLY external entry point)
#
# sop-extractor is INTERNAL ONLY — accessed by sop-api via Docker network:
#   http://sop-extractor:8001  (never exposed publicly)
#
# Get token from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=
