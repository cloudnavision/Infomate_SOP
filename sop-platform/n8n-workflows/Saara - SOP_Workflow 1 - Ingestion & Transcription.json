    {
      "parameters": {
        "jsCode": "function uuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    const v = c === 'x' ? r : (r & 0x3 | 0x8);\n    return v.toString(16);\n  });\n}\nconst batchItem = $('Process One File At a Time').first().json;\nconst sopId    = uuid();\nconst fileName = batchItem.file_name || 'recording.mp4';\nconst fileSize = batchItem.file_size_bytes || 0;\nconst spFileId = batchItem.sharepoint_file_id;\nconst cleanName = fileName.replace(/\\.(mp4|mkv|avi|mov|webm|wmv)$/i, '').replace(/[_-]/g, ' ').trim();\nconst ext = fileName.split('.').pop().toLowerCase();\nconst mimeMap = { 'mp4': 'video/mp4', 'mkv': 'video/x-matroska', 'avi': 'video/x-msvideo', 'mov': 'video/quicktime', 'webm': 'video/webm', 'wmv': 'video/x-ms-wmv' };\nconst mimeType = mimeMap[ext] || 'video/mp4';\nconst blobAccount   = $('Setup Config').first().json.AZURE_BLOB_ACCOUNT;\nconst blobContainer = $('Setup Config').first().json.AZURE_BLOB_CONTAINER;\nreturn [{ json: { sop_id: sopId, file_name: fileName, file_size_bytes: fileSize, sharepoint_file_id: spFileId, mime_type: mimeType, blob_url: `https://${blobAccount}.blob.core.windows.net/${blobContainer}/${sopId}/original.${ext}`, title: `${cleanName} — Knowledge Transfer`, meeting_date: new Date().toISOString().split('T')[0] }, binary: { data: $input.first().binary?.data ?? Object.values($input.first().binary ?? {})[0] } }];"
      },
