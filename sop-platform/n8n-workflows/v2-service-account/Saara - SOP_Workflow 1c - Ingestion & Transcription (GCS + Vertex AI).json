      "parameters": {
        "jsCode": "const drives = $input.all()[0].json.value || [];\nconst targetLibraryName = $('Setup Config').item.json.LIBRARY_NAME;\nlet targetDrive = drives.find(drive => drive.name && drive.name.toLowerCase() === targetLibraryName.toLowerCase());\nif (!targetDrive) {\n  const fallbacks = ['Documents', 'Shared Documents', 'Document Library'];\n  targetDrive = drives.find(drive => fallbacks.some(name => drive.name && drive.name.toLowerCase().includes(name.toLowerCase())));\n}\nif (!targetDrive) throw new Error(`Library \"${targetLibraryName}\" not found. Available: ${drives.map(d => d.name).join(', ')}`);\nreturn [{ json: { driveId: targetDrive.id, driveName: targetDrive.name, siteId: $('Access Saara Site').item.json.id } }];"
      },
