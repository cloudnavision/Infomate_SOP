    {
      "parameters": {
        "jsCode": "const rootSite = $input.all()[0].json;\nif (!rootSite || !rootSite.id) throw new Error('Could not get root site — check Saara - Sharepoint credential');\nconst webUrl = rootSite.webUrl || '';\nconst match = webUrl.match(/https:\\/\\/([^.]+\\.sharepoint\\.com)/);\nconst tenantDomain = match ? match[1] : null;\nif (!tenantDomain) throw new Error(`Could not extract tenant domain from webUrl: ${webUrl}`);\nconst targetSiteName = $('Setup Config').item.json.SITE_NAME;\nreturn [{ json: { tenantDomain, targetSiteName, constructedSiteUrl: `https://${tenantDomain}/sites/${targetSiteName}`, rootSiteId: rootSite.id } }];"
      },
