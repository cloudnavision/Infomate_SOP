        -2304
      ]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
      },
      "id": "d6db256c-a20e-40e4-ada5-baf0bef6d40e",
      "name": "Merge Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        4480,
        -2416
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse transcription response\nconst transcriptRaw = $('Gemini Transcription').first().json;\nconst transcriptText = transcriptRaw.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\nconst transcriptData = JSON.parse(transcriptText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim());\n\n// Parse screen share response\nconst screenRaw = $('Gemini Screen Detection').first().json;\nconst screenText = screenRaw.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\nconst screenData = JSON.parse(screenText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim());\n\nfunction mmssToSec(mmss) {\n  if (!mmss) return 0;\n  const parts = mmss.split(':').map(Number);\n  return parts[0] * 60 + (parts[1] || 0);\n}\n\nconst sopId    = $('Generate SOP ID1').first().json.sop_id;\nconst spFileId = $('Generate SOP ID1').first().json.sharepoint_file_id;\nconst fileName = $('Generate SOP ID1').first().json.file_name;\n\nconst lines = (transcriptData.transcript || []).map((line, idx) => ({\n  sop_id: sopId,\n  sequence: idx + 1,\n  speaker: line.speaker,\n  timestamp_sec: mmssToSec(line.start),\n  content: line.text\n}));\n\nconst participants = transcriptData.meeting_participants || transcriptData.speakers || [];\n\nconst lastLine = transcriptData.transcript?.[transcriptData.transcript.length - 1];\nconst videoDuration = lastLine ? mmssToSec(lastLine.end || lastLine.start) + 30 : 0;\n\nconst usage1 = transcriptRaw.usageMetadata || {};\nconst usage2 = screenRaw.usageMetadata || {};\nconst inputTokens  = (usage1.promptTokenCount     || 0) + (usage2.promptTokenCount     || 0);\nconst outputTokens = (usage1.candidatesTokenCount || 0) + (usage2.candidatesTokenCount || 0);\nconst apiCost = Math.round(((inputTokens * 0.15 / 1000000) + (outputTokens * 0.60 / 1000000)) * 10000) / 10000;\n\nreturn [{ json: { sop_id: sopId, sharepoint_file_id: spFileId, file_name: fileName, transcript_lines: lines, screen_changes: transcriptData.screen_changes || [], participants, screen_share_periods: screenData.screen_share_periods || [], video_duration_sec: videoDuration, speaker_count: participants.length, line_count: lines.length, api_cost: apiCost, input_tokens: inputTokens, output_tokens: outputTokens } }];"
      },
