      "parameters": {
        "jsCode": "const processedIds = new Set($input.all().map(item => item.json.file_id).filter(Boolean));\nconst allItems = $('List SOP Files').all()[0]?.json?.value ?? [];\nif (allItems.length === 0) return [{ json: { hasNewFiles: false, count: 0 } }];\nconst mp4Files = allItems.filter(item => {\n  if (item.folder) return false;\n  const byMime = item.file?.mimeType === 'video/mp4';\n  const byExt = typeof item.name === 'string' && item.name.toLowerCase().endsWith('.mp4');\n  return byMime || byExt;\n});\nconst newFiles = mp4Files.filter(file => !processedIds.has(file.id));\nif (newFiles.length === 0) return [{ json: { hasNewFiles: false, count: 0 } }];\nconst siteId  = $('Find Documents Library').first().json.siteId;\nconst driveId = $('Find Documents Library').first().json.driveId;\nreturn newFiles.map(file => ({ json: { hasNewFiles: true, sharepoint_file_id: file.id, file_name: file.name, file_size_bytes: file.size ?? 0, last_modified: file.lastModifiedDateTime ?? null, download_url: file['@microsoft.graph.downloadUrl'] ?? null, siteId, driveId } }));"
      },
