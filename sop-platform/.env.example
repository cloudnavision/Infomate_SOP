# ============================================================
# SOP Automation Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=sop_admin
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=sop_platform

# ── Backend API ───────────────────────────────────────────
# +asyncpg is the SQLAlchemy async driver — keep this exact format
DATABASE_URL=postgresql+asyncpg://sop_admin:dev_password_change_me@sop-postgres:5432/sop_platform
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Azure Blob Storage (leave blank for local development)
AZURE_BLOB_BASE_URL=
AZURE_BLOB_SAS_TOKEN=

# ── Frame Extractor ───────────────────────────────────────
EXTRACTOR_PORT=8001

# ── n8n ───────────────────────────────────────────────────
# Generate a random 32+ character string for this value
N8N_ENCRYPTION_KEY=change_me_random_32_chars_here

# AI APIs (required for pipeline to run — safe to leave blank during infra setup)
GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=

# ── Cloudflare (production only) ──────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
