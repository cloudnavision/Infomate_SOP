# ============================================================
# SOP Automation Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ── Database (Supabase) ───────────────────────────────────
# Use the transaction pooling connection string from Supabase dashboard:
# Project → Settings → Database → Connection string → Transaction pooler
# IMPORTANT: Transaction pooler uses port 6543, not 5432
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Backend API ───────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","https://sop.yourdomain.com"]

# Azure Blob Storage (leave blank for local development)
AZURE_BLOB_BASE_URL=
AZURE_BLOB_SAS_TOKEN=

# ── Frame Extractor ───────────────────────────────────────
EXTRACTOR_URL=http://sop-extractor:8001

# ── n8n (external hosted) ─────────────────────────────────
# Webhook base URL for your hosted n8n instance
# The API calls n8n at this URL; n8n calls the API back on port 8000
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook

# ── AI APIs ───────────────────────────────────────────────
GEMINI_API_KEY=
GOOGLE_VISION_API_KEY=

# ── Frontend ──────────────────────────────────────────────
# API URL the frontend uses to call the backend directly
# (No nginx proxy — frontend calls API directly)
# Local dev:  http://localhost:8000
# Production: https://api.sop.yourdomain.com (Cloudflare-exposed URL)
VITE_API_URL=http://localhost:8000

# ── Supabase Auth (Phase 1.5) ─────────────────────────────
# Supabase Dashboard → Settings → API
# Project URL (public)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# JWT Secret (backend only — used to validate auth tokens)
# Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Cloudflare Tunnel ─────────────────────────────────────
# cloudflared runs as a Docker Compose service (sop-cloudflared).
# TL creates the tunnel in Cloudflare Zero Trust dashboard and provides the token.
#
# Current route (Phase 3):
#   https://extractor.yourdomain.com → http://sop-extractor:8001
#
# Phase 6 routes (TL adds in dashboard — no rebuild needed):
#   https://api.yourdomain.com → http://sop-api:8000
#   https://sop.yourdomain.com → http://sop-frontend:5173
#
# Get token from: Cloudflare Zero Trust → Networks → Tunnels → your tunnel → Configure → Token
CLOUDFLARE_TUNNEL_TOKEN=
